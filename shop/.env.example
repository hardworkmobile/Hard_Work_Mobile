# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/shop_db?schema=public"

# ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ─── App URL (used in email links: password reset, etc.) ──────────────────────
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Square API — https://developer.squareup.com/apps ─────────────────────────
SQUARE_ACCESS_TOKEN=""
SQUARE_APPLICATION_ID=""
SQUARE_LOCATION_ID=""
SQUARE_ENVIRONMENT="sandbox"   # "sandbox" or "production"
NEXT_PUBLIC_SQUARE_APPLICATION_ID=""

# ─── Email (Resend) — https://resend.com ──────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Hard Work Mobile <onboarding@resend.dev>"

# ─── Storage (Cloudflare R2) — inspection photos, blog/testimonial images ─────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─── Google Calendar (Service Account) ─────────────────────────────────────────
# 1. Enable the Google Calendar API in your Google Cloud project.
# 2. Create a Service Account, download its JSON key.
# 3. Share your Google Calendar with the service account's email
#    ("Make changes to events" permission).
GOOGLE_CALENDAR_CLIENT_EMAIL=""
GOOGLE_CALENDAR_PRIVATE_KEY=""   # paste the full "private_key" value from the JSON key
GOOGLE_CALENDAR_ID=""            # usually your calendar's Google account email

# ─── Cron (Vercel Cron sends this as a Bearer token to /api/cron/*) ───────────
CRON_SECRET=""

# ─── One-off data migration only (scripts/migrate-from-mongo.ts) ──────────────
# Source MongoDB connection string from the old Express app. Remove after cutover.
ATLAS_URI=""
